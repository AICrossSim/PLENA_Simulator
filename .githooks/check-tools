#!/usr/bin/env bash
# Common tools submodule check utility
# Sourced by git hooks to check/update PLENA_Tools submodule

# Only set strict mode when executed directly, not when sourced
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    set -euo pipefail
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
TOOLS_DIR="$REPO_ROOT/PLENA_Tools"

check_tools_freshness() {
    # Check if submodule exists (can be file or directory)
    if [ ! -e "$TOOLS_DIR/.git" ]; then
        echo "[PLENA_Tools] Submodule not initialized. Run: git submodule update --init"
        return 1
    fi

    cd "$TOOLS_DIR"

    # Fetch latest from remote (silently fail if offline)
    git fetch origin main --quiet 2>/dev/null || return 0

    LOCAL=$(git rev-parse HEAD)
    REMOTE=$(git rev-parse origin/main 2>/dev/null || echo "$LOCAL")

    if [ "$LOCAL" != "$REMOTE" ]; then
        BEHIND=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo "?")
        echo ""
        echo "========================================"
        echo "[PLENA_Tools] Submodule is $BEHIND commit(s) behind origin/main"
        echo "  Local:  $(git rev-parse --short HEAD)"
        echo "  Remote: $(git rev-parse --short origin/main)"
        echo ""
        echo "  To update: git submodule update --remote PLENA_Tools"
        echo "========================================"
        echo ""
        return 1
    fi
    return 0
}

update_tools() {
    echo "[PLENA_Tools] Updating submodule to latest..."
    cd "$REPO_ROOT"
    git submodule update --init --remote PLENA_Tools
    echo "[PLENA_Tools] Updated to: $(cd PLENA_Tools && git rev-parse --short HEAD)"
}

# Auto-update if PLENA_AUTO_UPDATE_TOOLS=1
auto_update_tools_if_enabled() {
    if [ "${PLENA_AUTO_UPDATE_TOOLS:-0}" = "1" ]; then
        if ! check_tools_freshness 2>/dev/null; then
            update_tools
        fi
    else
        check_tools_freshness || true
    fi
}
